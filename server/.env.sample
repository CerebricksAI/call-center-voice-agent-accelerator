# .env

# --- Required: Core (needed for both azd up and local dev) ---
AZURE_VOICE_LIVE_API_KEY=<Find the key from your AI foundry resource>
AZURE_VOICE_LIVE_ENDPOINT=<Find the endpoint from your AI foundry resource>
VOICE_LIVE_MODEL=gpt-4o-mini

# --- Telephony Provider: set ONE to activate that provider ---
ACS_CONNECTION_STRING=<Find the connection string from your Communication Service resource>
# TWILIO_AUTH_TOKEN=<Twilio Auth Token for webhook signature validation>
# INFOBIP_API_KEY=<Infobip API Key>
# INFOBIP_API_BASE_URL=<e.g. https://xxxxx.api.infobip.com>
# GENESYS_API_KEY=<Genesys API Key for AudioHook authentication>

# --- Optional: latency tuning (time-to-first-audio) ---
# Profile presets: default | balanced | aggressive
# VOICE_LIVE_LATENCY_MODE=default
#
# balanced:  LOW EOU, 700ms timeout, 200 token cap, 100ms TTS buffer
# aggressive: LOW EOU, 600ms timeout, 150 token cap, no noise reduction, 50ms buffer
#
# Fine-grained overrides (optional; override the active profile when set):
# VOICE_LIVE_EOU_THRESHOLD=low          # default | low | medium | high
# VOICE_LIVE_EOU_TIMEOUT_MS=600         # max wait after pause before turn ends
# VOICE_LIVE_EOU_MODE=auto              # auto | text | smart | vad
#   auto: smart EOU for gpt-realtime* models, text EOU for gpt-4o-mini (cascaded)
#   vad: semantic VAD only (fallback if smart EOU fails on your endpoint)
# VOICE_LIVE_SILENCE_DURATION_MS=400    # used when eou_mode=vad
# VOICE_LIVE_MAX_RESPONSE_TOKENS=150    # cap assistant reply length per turn
# VOICE_LIVE_NOISE_REDUCTION=true       # false saves ~20-80ms on noisy paths
# VOICE_LIVE_ECHO_CANCELLATION=true
# TTS_PLAYBACK_BUFFER_MS=200            # pre-buffer before ambient+TTS playback (0 when ambient=none)
#
# For lowest TTFA on native-audio models, try gpt-realtime or gpt-realtime-mini.
# If you get 403 on connect, the model is not enabled on your resource/region —
# use gpt-realtime or fall back to gpt-4o-mini (cascaded, works everywhere).
# VOICE_LIVE_MODEL=gpt-realtime
#
# System prompt: compact (~63% smaller, same rules) or full
VOICE_LIVE_PROMPT_MODE=compact
# VOICE_LIVE_LATENCY_MODE=balanced
#
# Voice overrides (optional; defaults in app/agent_persona.py):
# VOICE_NAME=en-US-Ava:DragonHDLatestNeural
# VOICE_TEMPERATURE=0.8
# VOICE_STYLE=chat
# VOICE_RATE=medium

# INPUT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Key Details: LLM analyzes the full transcript after each caller turn via a separate
# text-only Voice Live session (parallel, does not interrupt the voice agent).
# In Azure, extract uses AZURE_USER_ASSIGNED_IDENTITY_CLIENT_ID (same as the voice agent).
# Locally, set AZURE_VOICE_LIVE_API_KEY.
# EXTRACT_MODEL defaults to VOICE_LIVE_MODEL. EXTRACT_MAX_PARALLEL=1, EXTRACT_TIMEOUT_S=30
# End-of-call summary: SUMMARY_MODEL, SUMMARY_TIMEOUT_S=20, SUMMARY_PROMPT_MODE=compact|full,
# SUMMARY_MAX_CHARS=5000, SUMMARY_MAX_TURNS=32, SUMMARY_MAX_OUTPUT_TOKENS=220,
# SUMMARY_HEAD_TURNS=4, SUMMARY_TAIL_TURNS=16, SUMMARY_PREFETCH_ON_CLOSE=true
# Optional Voice Live Basic tier pricing (USD per 1M tokens, Azure Speech Standard path):
# VOICE_LIVE_PRICE_TEXT_INPUT_PER_1M=0.66
# VOICE_LIVE_PRICE_TEXT_CACHED_INPUT_PER_1M=0.33
# VOICE_LIVE_PRICE_TEXT_OUTPUT_PER_1M=2.64
# VOICE_LIVE_PRICE_AUDIO_INPUT_PER_1M=15
# VOICE_LIVE_PRICE_AUDIO_CACHED_INPUT_PER_1M=0.33
# VOICE_LIVE_PRICE_AUDIO_OUTPUT_PER_1M=33
# Optional caller STT pricing (INPUT_TRANSCRIPTION_MODEL, USD per 1M tokens):
# TRANSCRIBE_PRICE_TEXT_INPUT_PER_1M=1.25
# TRANSCRIBE_PRICE_TEXT_OUTPUT_PER_1M=5
# TRANSCRIBE_PRICE_AUDIO_INPUT_PER_1M=3
# AUTO_END_CALL_DELAY_S=5  # seconds after agent closes interview before finalize
# ACS_DEV_TUNNEL=<Your devtunnel/ngrok URL for local ACS webhook testing>

# --- Web client login (hardcoded in app/auth_settings.py — no Container App env needed) ---
# Edit server/app/auth_settings.py for tenant ID, client ID, client secret, demo password.
# Optional local overrides in .env:
# SESSION_COOKIE_SECURE=false   # required for http://localhost login cookies
# AZURE_AD_REDIRECT_URI=http://localhost:8080/auth/callback
# Ambient Scenes: adds realistic background audio to simulate real-world call environments
# Options: none (default/disabled), office, call_center
# You can also add custom audio files - see README for details
AMBIENT_PRESET=none

# --- Cosmos DB persistence (optional; one document per call) ---
# Leave COSMOS_ENDPOINT unset to disable persistence entirely.
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=<account key for local dev; omit to use managed identity in Azure>
# COSMOS_DATABASE=voiceagent
# COSMOS_CONTAINER=calls
# COSMOS_TIMEOUT_S=15
# Each document includes: transcript, metrics, events, callSummary, keyDetails
#
# Call history UI reads saved calls via GET /api/calls and GET /api/calls/<callId>
# (requires login; Cosmos must be configured).